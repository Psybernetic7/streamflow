{
  "name": "streamflow",
  "version": "1.0.3",
  "description": "Watch your favorite Movies and TV shows",
  "author": "Rajib Roy",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.streamflow.desktop",
    "productName": "StreamFlow",
    "publish": [
      {
        "provider": "github"
      }
    ],
    "files": [
      "electron/**/*",
      "streamer/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "ffmpeg/",
        "to": "ffmpeg"
      }
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage",
      "category": "Video"
    }
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "memory-chunk-store": "^1.3.5",
    "node-fetch": "^3.3.2",
    "webtorrent": "^2.5.1"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  }
}
