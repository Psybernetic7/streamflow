{
  "name": "streamflow",
  "version": "1.0.0",
  "description": "Torrent streaming desktop app",
  "author": "Your Name",
  "main": "electron/main.js",
  "private": true,

  "scripts": {
    "dev": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },

  "build": {
    "appId": "com.streamflow.desktop",
    "productName": "StreamFlow",
    "publish": [
    {
      "provider": "github"
      
    }
  ],
    "files": [
      "electron/**/*",
      "streamer/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "ffmpeg/",
        "to": "ffmpeg"
      }
    ],
    "asar": true,
    "win": {
      "target": [
    "nsis",
    "portable"
  ]
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
  "target": "AppImage",
  "category": "Video"
}
  },
  "dependencies": {
    "webtorrent": "^2.5.1",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  }
}